{
  "manifest_version": 3,
  "name": "CyberTerm OS — Productivity Dashboard",
  "version": "2.0.0",
  "description": "A unified cyberpunk CRT-style productivity dashboard. Todo, journal, bookmarks, comms, system stats — injected into every tab.",

  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "management",
    "bookmarks"
  ],

  "host_permissions": ["<all_urls>"],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "css": [],
      "run_at": "document_end",
      "all_frames": false
    }
  ],

  "commands": {
    "toggle-theme": {
      "suggested_key": { "default": "Ctrl+Shift+Y", "mac": "Command+Shift+Y" },
      "description": "Toggle CyberTerm theme"
    },
    "open-journal": {
      "suggested_key": { "default": "Ctrl+J", "mac": "Command+J" },
      "description": "Open Journal panel"
    },
    "open-todo": {
      "suggested_key": { "default": "Ctrl+Shift+T", "mac": "Command+Shift+T" },
      "description": "Open To-Do panel"
    }
  },

  "web_accessible_resources": [
    {
      "resources": [
        "sidebar.html",
        "styles/theme.css",
        "styles/sidebar.css",
        "styles/overlay.css",
        "modules/todo.js",
        "modules/journal.js",
        "modules/bookmarks.js",
        "modules/system.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
